# ─── Django ───────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
# IMPORTANT: change this in production — use: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=dev-secret-key-change-in-production
# Allow insecure key in dev only — NEVER set in production
DJANGO_ALLOW_INSECURE_KEY=True
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Portal JWT Secret (must be DIFFERENT from SECRET_KEY) ────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
PORTAL_JWT_SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">

# ─── Database ─────────────────────────────────────────────────────
DB_PASSWORD=trident_dev_2026
DATABASE_URL=postgresql://trident:trident_dev_2026@db:5432/trident_erp

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── Email ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ─── SMS / OTP (MSG91) ────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=TRIDNT

# ─── File Storage ─────────────────────────────────────────────────
# Set to 's3' to use S3-compatible storage (MinIO / OCI / AWS)
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=     # e.g. http://minio:9000 for local MinIO

# ─── GST / E-way / E-invoice (Webtel / GSTN) ─────────────────────
GSTN_CLIENT_ID=
GSTN_CLIENT_SECRET=
WEBTEL_API_KEY=

# ─── Sentry (error monitoring) ────────────────────────────────────
SENTRY_DSN=

# ─── Frontend ─────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api

# ─── Gunicorn (production) ────────────────────────────────────────
# Recommended: 2*CPU+1 for sync workers, 2-4 for async uvicorn workers
# GUNICORN_WORKERS=9
